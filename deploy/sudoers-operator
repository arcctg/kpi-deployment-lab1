operator ALL=(ALL) NOPASSWD: \
    /usr/bin/systemctl start mywebapp.socket, \
    /usr/bin/systemctl stop mywebapp.socket, \
    /usr/bin/systemctl restart mywebapp.socket, \
    /usr/bin/systemctl start mywebapp.service, \
